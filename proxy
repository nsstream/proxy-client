#!/usr/bin/env bash
set -e

# ========== Trojan Node Configuration ==========
TROJAN_REMOTE_ADDR=
TROJAN_REMOTE_PORT=443
TROJAN_PASSWORD=
TROJAN_SNI=
TROJAN_SSL_VERIFY=true
# Websocket (set TROJAN_WS_ENABLED=true to enable)
TROJAN_WS_ENABLED=false
TROJAN_WS_PATH=/
# MUX multiplexing
TROJAN_MUX_ENABLED=false
# ========== Local Proxy Ports ==========
SOCKS5_PROXY_PORT=1080
HTTP_PROXY_PORT=8118
# ========== Docker Settings ==========
CONTAINER_NAME=proxy-client
IMAGE_NAME=proxy-client

function logs_proxy() {
	docker logs -f ${CONTAINER_NAME}
}

function rm_proxy() {
	docker rm -f ${CONTAINER_NAME} &> /dev/null || true
}

function run_proxy() {
	rm_proxy
	docker run -d --name ${CONTAINER_NAME} \
		-p ${SOCKS5_PROXY_PORT}:1080 \
		-p ${HTTP_PROXY_PORT}:8118 \
		-e TROJAN_REMOTE_ADDR=${TROJAN_REMOTE_ADDR} \
		-e TROJAN_REMOTE_PORT=${TROJAN_REMOTE_PORT} \
		-e TROJAN_PASSWORD=${TROJAN_PASSWORD} \
		-e TROJAN_SNI=${TROJAN_SNI:-$TROJAN_REMOTE_ADDR} \
		-e TROJAN_SSL_VERIFY=${TROJAN_SSL_VERIFY} \
		-e TROJAN_WS_ENABLED=${TROJAN_WS_ENABLED} \
		-e TROJAN_WS_PATH=${TROJAN_WS_PATH} \
		-e TROJAN_MUX_ENABLED=${TROJAN_MUX_ENABLED} \
		${IMAGE_NAME} &> /dev/null
}

function proxy_on() {
	echo "export http_proxy=localhost:${HTTP_PROXY_PORT} https_proxy=localhost:${HTTP_PROXY_PORT} no_proxy=localhost,127.0.0.0/8,::1"
}

function proxy_off() {
	echo "unset http_proxy https_proxy"
}

if [ -z "$1" ]; then
	echo "Usage: proxy {on|off|logs|docker}"
	exit 0
fi

case "$1" in
	on)
		rm_proxy
		run_proxy
		proxy_on
		;;
	off)
		rm_proxy
		proxy_off
		;;
	docker)
		echo "--link ${CONTAINER_NAME} -e http_proxy=${CONTAINER_NAME}:${HTTP_PROXY_PORT} -e https_proxy=${CONTAINER_NAME}:${HTTP_PROXY_PORT}"
		;;
	logs)
		logs_proxy
		;;
	*)
		echo "Usage: proxy {on|off|logs|docker}"
		exit 1
		;;
esac
